{
    "name":  "@mutimemoagent/sdk",
    "version":  "0.1.0",
    "private":  true,
    "description":  "Memograph SDK 鈥?install, init, connect, and manage memory agents",
    "type":  "module",
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
